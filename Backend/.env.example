# ─────────────────────────────────────────────────────────
#  TalentFlow LMS — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────


# ── ENVIRONMENT ───────────────────────────────────────────
# "development" → enables /docs, disables Secure cookies
# "production"  → disables /docs, enables Secure cookies
ENVIRONMENT=development


# ── DATABASE ──────────────────────────────────────────────
# Option A: Single URL (Render provides this automatically)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B: Individual variables (local dev / Docker)
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=talent_flow_db


# ── JWT AUTH ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_to_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# In production: use your actual deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# ── ADMIN SEED ────────────────────────────────────────────
# Used by scripts/create_admin.py to bootstrap the first admin
FIRST_ADMIN_EMAIL=admin@talentflow.com
FIRST_ADMIN_PASSWORD=ChangeThisPassword123!
